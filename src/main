#include "./libs/transporter.h"
#include "./libs/transporter.cpp"

#include "headers/arm_config.h"


#include <Servo.h>



//#define BAUD 9600



Servo Gripper;
Servo Bottom;
Servo Right;
Servo Left;

Transporter transporter;




String reciveData;
String tmp = "";

char* data;

uint8_t gripper_angle = 0;
uint8_t bottom_angle = 0;
uint8_t right_angle = 0;
uint8_t left_angle = 0;


typedef unsigned long ul;
ul currentMillis;
ul elapsedMillis;
ul lastMillis = 0;




void setup(void) {
  transporter.init();
  transporter.stop();
  delay(100);


  initArm();
  delay(100);


#ifdef BAUD
  Serial.begin(9600);
#endif

transporter.run();

}

void loop(void) {

#ifdef BAUD
  getData();
#endif

  if (transporter.isSensor()) {
    transporter.stop();
    cooperateWithTransporter();
    transporter.run();
  }

}



///////////////////////////////////////////////////////////

void initArm() {
  Gripper.attach(GRIPPER_PIN);

  Bottom.attach(BOTTOM_PIN);
  Right.attach(RIGHT_PIN);
  Left.attach(LEFT_PIN);

  delay(100);

  gripperClose();

  bottom_angle = BOTTOM_START_POS;
  right_angle = RIGHT_START_POS;
  left_angle = LEFT_START_POS;

  Bottom.write(BOTTOM_START_POS);
  Right.write(RIGHT_START_POS);
  Left.write(LEFT_START_POS);
}

///////////////////////////////////////////////////////////



void gripperOpen() {
  Gripper.write(GRIPPER_MAX);
  gripper_angle = (uint8_t)GRIPPER_MAX;
}

void gripperClose() {
  Gripper.write(GRIPPER_MIN);
  gripper_angle = (uint8_t)GRIPPER_MIN;
}





