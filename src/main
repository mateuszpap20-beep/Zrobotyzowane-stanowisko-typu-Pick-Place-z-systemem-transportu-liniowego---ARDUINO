void cooperateWithTransporter() {

  while (1) {
    gripperOpen();

    int bottom_current_position = Bottom.read();
    int right_current_position = Right.read();
    int left_current_position = Left.read();

    unsigned long _time, _old = 0;

part1:
    _time = millis();
    if (_time - _old >= 15) {
      _old = _time;
      Bottom.write(bottom_current_position++);
      if (Bottom.read() == 145)
        goto part2;
    }
    goto part1;


part2:
    _time = millis();
    if (_time - _old >= 15) {
      _old = _time;
      if (Right.read() != 34)
        Right.write(right_current_position++);
      if (Left.read() != 100)
        Left.write(left_current_position--);
      if (Right.read() == 34 && Left.read() == 100)
        goto part3;
    }
    goto part2;


part3:
    gripperClose();
    delay(100);
    goto part4;
    goto part3;


part4:
    _time = millis();
    if (_time - _old >= 15) {
      _old = _time;
      if (Right.read() != 0)
        Right.write(right_current_position--);
      if (Left.read() != 120)
        Left.write(left_current_position++);
      if (Right.read() == 0 && Left.read() == 120)
        goto part5;
    }
    goto part4;


part5:
    _time = millis();
    if (_time - _old >= 15) {
      _old = _time;
      if (Bottom.read() != 10)
        Bottom.write(bottom_current_position--);
      if (Bottom.read() == 10)
        goto part6;
    }
    goto part5;


part6:
    _time = millis();
    if (_time - _old >= 15) {
      _old = _time;
      if (Right.read() != 35)
        Right.write(right_current_position++);
      if (Left.read() != 100)
        Left.write(left_current_position--);
      if (Right.read() == 35 && Left.read() == 100)
        goto part7;
    }
    goto part6;


part7:
    delay(100);
    gripperOpen();
    delay(100);
    goto part8;
    goto part7;


part8:
    _time = millis();
    if (_time - _old >= 15) {
      _old = _time;
      if (Right.read() != 0)
        Right.write(right_current_position--);
      if (Left.read() != 120)
        Left.write(left_current_position++);
      if (Right.read() == 0 && Left.read() == 120)
        goto part9;
    }
    goto part8;


part9:
    gripperClose();
    delay(100);
    goto part10;
    goto part9;


part10:
    _time = millis();
    if (_time - _old >= 15) {
      _old = _time;
      if (Bottom.read() != 90)
        Bottom.write(bottom_current_position++);
      if (Bottom.read() == 90)
        break;
    }
    goto part10;
  }

}
